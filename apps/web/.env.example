# Copy to apps/web/.env.local
NEXT_PUBLIC_SUPABASE_URL=[get from supabase dashboard]
# Dashboard → Project Settings → API → publishable (anon) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=[get from supabase dashboard]

# Optional — override portal URLs on the root landing page (e.g. Vercel preview)
# NEXT_PUBLIC_CLIENT_ORIGIN=https://app.corduroytech.ai
# NEXT_PUBLIC_STAFF_ORIGIN=https://staff.corduroytech.ai