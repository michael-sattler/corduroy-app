FROM node:22-bookworm-slim
WORKDIR /app

COPY package.json package-lock.json ./
COPY apps/api/package.json apps/api/
RUN npm ci

COPY apps/api ./apps/api
COPY scripts/docker-api-dev-entrypoint.sh /usr/local/bin/docker-api-dev-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-api-dev-entrypoint.sh

EXPOSE 4000
ENV NODE_ENV=development
ENV PORT=4000
ENTRYPOINT ["docker-api-dev-entrypoint.sh"]
CMD ["npm", "run", "dev", "--workspace=@corduroy/api"]
