# Supabase — corduroy-app
#
# Project URL: https://iggvqbqqzujixshiffqe.supabase.co
# Dashboard:   https://supabase.com/dashboard/project/iggvqbqqzujixshiffqe

# Next.js (apps/web/.env.local)
NEXT_PUBLIC_SUPABASE_URL=https://iggvqbqqzujixshiffqe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Seed script only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Database password (Project Settings → Database). Used by `npm run db:push`
# when the CLI cannot create a temporary login role (403 on "Initialising login role").
SUPABASE_DB_PASSWORD=

# Orchestration API (apps/api) — same Supabase project
SUPABASE_URL=https://iggvqbqqzujixshiffqe.supabase.co
SUPABASE_ANON_KEY=

# Staff LLM dialogue (apps/web) — server-only, never expose to the browser.
# Phase 1 provider is Anthropic. When ANTHROPIC_API_KEY is unset the dialogue
# runs in a deterministic preview stub. Prefer a zero-retention / no-training tier.
# Use an exact model id from your account (GET https://api.anthropic.com/v1/models);
# there is no "-latest" alias. Cheapest for eval: claude-haiku-4-5-20251001.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
